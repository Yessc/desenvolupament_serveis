<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="700.0"
            xmlns="http://javafx.com/javafx/19"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.project.Controller">

    <children>

        <!-- Chat -->
        <ScrollPane fx:id="scrollPane"
                    AnchorPane.topAnchor="16.0"
                    AnchorPane.leftAnchor="16.0"
                    AnchorPane.rightAnchor="16.0"
                    AnchorPane.bottomAnchor="100.0"
                    hbarPolicy="NEVER">

            <content>
                <VBox fx:id="chatBox"
                      spacing="10.0"
                      prefWidth="660.0"/>
            </content>

        </ScrollPane>

        <HBox spacing="10.0"
              AnchorPane.leftAnchor="16.0"
              AnchorPane.rightAnchor="16.0"
              AnchorPane.bottomAnchor="16.0"
              alignment="CENTER_LEFT">

            <children>

                <HBox spacing="5" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">

                    <children>
                        <ImageView fx:id="previewImage"
                                   fitHeight="35"
                                   fitWidth="35"
                                   preserveRatio="true"/>

                        <TextField fx:id="messageField"
                                   promptText="Escribe un mensaje..."
                                   onAction="#sendMessage"
                                   prefHeight="40"
                                   HBox.hgrow="ALWAYS"/>

                    </children>

                </HBox>

                <Button fx:id="sendButton"
                        text="Enviar"
                        onAction="#sendMessage"
                        prefWidth="80"
                        prefHeight="40"/>

                <Button fx:id="imageButton"
                        text="Imagen"
                        onAction="#selectImage"
                        prefWidth="80"
                        prefHeight="40"/>

                <Button fx:id="cancelButton"
                        text="Cancelar"
                        onAction="#cancelRequest"
                        prefWidth="80"
                        prefHeight="40"
                        disable="true"/>

            </children>

        </HBox>

    </children>

</AnchorPane>